{
  "name": "@loomflo/cli",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "loomflo": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "theme:preview": "tsx scripts/theme-preview.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^6",
    "@loomflo/core": "workspace:*",
    "chalk": "^5",
    "cli-table3": "^0.6",
    "commander": "^13.0.0",
    "ora": "^8",
    "ws": "^8.20.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "nock": "^14",
    "strip-ansi": "^7",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=20"
  }
}
