{
  "name": "@loomflo/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.0.0",
    "async-mutex": "^0.5.0",
    "fastify": "^5.0.0",
    "picomatch": "^4.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/picomatch": "^3.0.0",
    "tsup": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
