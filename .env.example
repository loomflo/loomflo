# Loomflo — Environment Variables
# Copy this file to .env and fill in your values.

# Anthropic credentials (provide ONE of the following):

# Option 1: API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option 2: OAuth token (from Claude.ai OAuth flow)
# ANTHROPIC_OAUTH_TOKEN=your-oauth-token-here

# Option 3: If you have Claude Code installed and logged in,
# Loomflo will automatically use your Claude Code OAuth credentials
# from ~/.claude/.credentials.json — no env var needed.

# Optional: OpenAI API key (not yet supported)
# OPENAI_API_KEY=sk-your-key-here

# Optional: Ollama base URL (not yet supported)
# OLLAMA_BASE_URL=http://localhost:11434
