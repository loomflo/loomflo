{
  "name": "loomflo",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "AI Agent Orchestration Framework",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "dev:full": "concurrently \"pnpm --filter @loomflo/core dev\" \"pnpm --filter @loomflo/dashboard dev\"",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.17.0",
    "globals": "^17.4.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2",
    "concurrently": "^9.0.0",
    "vitest": "^3.0.4"
  }
}
